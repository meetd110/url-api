# Cloudflare R2 credentials
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens

# Your Cloudflare Account ID (found in the right sidebar of any R2 page)
R2_ACCOUNT_ID=your_account_id_here

# R2 API Token credentials (create under R2 → Manage R2 API Tokens)
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here

# The name of your R2 bucket
R2_BUCKET_NAME=your_bucket_name_here

# (Optional) Port to run the server on. Defaults to 3000.
# PORT=3000
